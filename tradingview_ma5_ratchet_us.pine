//@version=6
indicator("MA5 Ratchet US", overlay=true, max_labels_count=500)

maLength = input.int(5, "MA length", minval=1)
volLength = input.int(20, "Volume MA length", minval=1)
volMultiplier = input.float(1.45, "Massive volume multiplier", minval=0.1, step=0.05)
volHighDays = input.int(3, "Consecutive high-volume days", minval=1)
volHighMultiplier = input.float(1.0, "High-volume multiplier", minval=0.1, step=0.05)
massiveWindow = input.int(7, "Massive volume window", minval=1)
massiveMinCount = input.int(1, "Minimum massive-volume count", minval=1)
reentryPct = input.float(4.5, "B2 distance to MA5 %", minval=0.1, step=0.1)
stopMa5Pct = input.float(7.5, "Strategy MA5 defense %", minval=0.1, step=0.1)
below20StopDays = input.int(2, "Consecutive closes below MA20", minval=0)
hardStopPct = input.float(20.0, "Cost stop %", minval=0.1, step=0.1)

showHoldingBg = input.bool(true, "Show holding background", group="Display")
showSignalMarkers = input.bool(false, "Show B1/B2/S signal markers", group="Display")
showExecutionMarkers = input.bool(true, "Show next-open buy/sell markers", group="Display")
showIntervalLabels = input.bool(true, "Show interval % label", group="Display")
showDefense25 = input.bool(false, "Show MA5 - 2.5% line", group="Display")
showStrategyDefense = input.bool(true, "Show strategy defense line", group="Display")
showMa50 = input.bool(false, "Show MA50", group="Display")
showBarColor = input.bool(false, "Color signal candles", group="Display")

ma5 = ta.sma(close, maLength)
ma20 = ta.sma(close, 20)
ma50 = ta.sma(close, 50)
volMa = ta.sma(volume, volLength)

priceAboveMa5 = not na(ma5) and close > ma5
volHigh = not na(volMa) and volume > volMa * volHighMultiplier
volHighCount = ta.sma(volHigh ? 1.0 : 0.0, volHighDays) * volHighDays
volDaysHigh = volHighCount == volHighDays
massiveVol = not na(volMa) and volume >= volMa * volMultiplier
massiveCount = ta.sma(massiveVol ? 1.0 : 0.0, massiveWindow) * massiveWindow
hasMassiveVol = massiveCount >= massiveMinCount

recentHigh60 = ta.highest(close, 60)
ma50Rising = not na(ma50[5]) and ma50 > ma50[5]
aboveMa50 = not na(ma50) and close > ma50
nearStageHigh = recentHigh60 > 0 and close >= recentHigh60 * 0.80
bullQualityOk = aboveMa50 and ma50Rising and nearStageHigh

fullRange = high - low
body = math.abs(close - open)
upperShadow = high - math.max(open, close)
upperShadowOk = upperShadow <= math.max(body * 0.75, fullRange * 0.20)
distToMa5 = not na(ma5) and ma5 != 0 ? math.abs(close - ma5) / ma5 : na

// Core web-aligned signal rules only. Optional MA filters and weak-repair exits
// are intentionally not modeled in this TradingView indicator.
b1 = priceAboveMa5 and volDaysHigh and hasMassiveVol

var bool trendConfirmed = false
wasTrendConfirmed = trendConfirmed

if b1
    trendConfirmed := true

b2 = wasTrendConfirmed and massiveVol and priceAboveMa5 and not na(distToMa5) and distToMa5 <= reentryPct / 100 and close > open and bullQualityOk and upperShadowOk

failedTrend = not na(ma5) and close < ma5 * 0.925
if failedTrend
    trendConfirmed := false

buyTargetPct = b2 ? 100.0 : b1 ? 50.0 : 0.0
buySignal = buyTargetPct > 0

var bool inTrade = false
var float entryPrice = na
var string entryStage = ""
var float positionPct = 0.0
var bool pendingBuy = false
var string pendingBuyStage = ""
var float pendingBuyTargetPct = 0.0
var bool pendingSell = false

sellExecution = pendingSell and inTrade
if sellExecution
    intervalPct = not na(entryPrice) and entryPrice != 0 ? (open / entryPrice - 1) * 100 : na
    if showIntervalLabels and not na(intervalPct)
        labelColor = intervalPct >= 0 ? color.new(color.teal, 0) : color.new(color.red, 0)
        labelText = entryStage + " -> sell\n" + str.tostring(intervalPct, "#.##") + "%"
        label.new(bar_index, high, labelText, style=label.style_label_down, color=labelColor, textcolor=color.white, size=size.small)
    inTrade := false
    entryPrice := na
    entryStage := ""
    positionPct := 0.0
    pendingSell := false

buyExecution = pendingBuy and pendingBuyTargetPct > positionPct + 1
addExecution = buyExecution and inTrade
if buyExecution
    addedPct = pendingBuyTargetPct - positionPct
    entryPrice := inTrade and not na(entryPrice) and pendingBuyTargetPct > 0 ? (entryPrice * positionPct + open * addedPct) / pendingBuyTargetPct : open
    inTrade := true
    entryStage := pendingBuyStage
    positionPct := pendingBuyTargetPct
    pendingBuy := false
    pendingBuyStage := ""
    pendingBuyTargetPct := 0.0

entrySignal = buySignal and buyTargetPct > positionPct + 1 and not pendingBuy
if entrySignal
    pendingBuy := true
    pendingBuyStage := b2 ? "B2" : "B1"
    pendingBuyTargetPct := buyTargetPct

var int below20Days = 0
if inTrade
    below20Days := not na(ma20) and close < ma20 ? below20Days + 1 : 0
else
    below20Days := 0

defenseStop = inTrade and not na(ma5) and close < ma5 * (1 - stopMa5Pct / 100)
trendStop = inTrade and below20StopDays > 0 and below20Days >= below20StopDays
costStop = inTrade and not na(entryPrice) and close < entryPrice * (1 - hardStopPct / 100)
sellSignal = (defenseStop or trendStop or costStop) and not pendingSell

if sellSignal
    pendingSell := true

bgColor = sellExecution ? color.new(color.red, 84) : inTrade ? color.new(color.teal, 90) : na
bgcolor(showHoldingBg ? bgColor : na, title="Holding background")

plot(ma5, "MA5", color=color.new(color.blue, 0), linewidth=2)
plot(ma20, "MA20", color=color.new(color.orange, 0))
plot(showMa50 ? ma50 : na, "MA50", color=color.new(color.gray, 20))
plot(showDefense25 ? ma5 * 0.975 : na, "MA5 - 2.5%", color=color.new(color.red, 0), linewidth=1)
plot(showStrategyDefense ? ma5 * (1 - stopMa5Pct / 100) : na, "Strategy MA5 defense", color=color.new(color.red, 35), linewidth=1, style=plot.style_line)

plotshape(showSignalMarkers and entrySignal and b1, title="B1 signal", text="B1", style=shape.circle, location=location.belowbar, color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny)
plotshape(showSignalMarkers and entrySignal and b2, title="B2 signal", text="B2", style=shape.circle, location=location.belowbar, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
plotshape(showSignalMarkers and sellSignal, title="Sell signal", text="S", style=shape.triangledown, location=location.abovebar, color=color.new(color.orange, 0), textcolor=color.white, size=size.tiny)
plotshape(showExecutionMarkers and buyExecution and not addExecution, title="Buy execution", text="BUY", style=shape.arrowup, location=location.belowbar, color=color.new(color.teal, 0), textcolor=color.white, size=size.tiny)
plotshape(showExecutionMarkers and addExecution, title="Add execution", text="ADD", style=shape.arrowup, location=location.belowbar, color=color.new(color.blue, 0), textcolor=color.white, size=size.tiny)
plotshape(showExecutionMarkers and sellExecution, title="Sell execution", text="SELL", style=shape.arrowdown, location=location.abovebar, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)

barcolor(showBarColor ? (b1 ? color.new(color.lime, 70) : b2 ? color.new(color.blue, 70) : sellSignal ? color.new(color.red, 70) : na) : na)

alertcondition(b1, "MA5 Ratchet B1", "B1 trend-confirm signal")
alertcondition(b2, "MA5 Ratchet B2", "B2 reentry/add signal")
alertcondition(sellSignal, "MA5 Ratchet Sell Signal", "Sell signal at close; execution is next bar open")
alertcondition(buyExecution, "MA5 Ratchet Buy Execution", "Buy at next bar open")
alertcondition(sellExecution, "MA5 Ratchet Sell Execution", "Sell at next bar open")
